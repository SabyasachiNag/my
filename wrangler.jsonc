{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "my",
	"main": "./src/worker.ts",
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["nodejs_compat"],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "myaa",
		},
	],
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "myemd","preview_bucket_name": "myaa",
		},
	],
	// Worker Loader for plugin sandboxing
//	"worker_loaders": [
//		{
//			"binding": "LOADER",
//		},
//	],
}
